# Main Agent
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
MAIN_MODEL=deepseek-v4-flash

# Summarization
SUMMARIZATION_API_KEY=
SUMMARIZATION_API_BASE=https://api.deepseek.com
SUMMARIZATION_MODEL=deepseek-v4-flash

# Vision
VISION_API_KEY=
VISION_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen3.5-flash

# Embedding
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v2
DATA_DIR=./data

# ChromaDB HTTP Server
CHROMA_HOST=localhost
CHROMA_PORT=8001

# OSS
OSS_ENABLE=false
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=train-agent
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# TTS
TTS_API_KEY=
TTS_API_BASE=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
TTS_MODEL=qwen3-tts-flash

# Tracing
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT="train-agent"